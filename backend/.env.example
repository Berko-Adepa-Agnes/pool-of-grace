# Pool of Grace Backend Environment Variables
# Copy this file to .env and fill in your values

# Server port
PORT=5000

# JWT secret key for authentication (change this to a secure random string)
JWT_SECRET=your_secret_key_here

# PostgreSQL database connection string
# We recommend using Neon (neon.tech) for a free PostgreSQL database
# Format: postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Leave empty to use JSON file fallback (no database required)
DATABASE_URL=

# Node environment: 'development' or 'production'
NODE_ENV=development
